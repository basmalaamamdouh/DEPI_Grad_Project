def cb_ai_draft(email_addr: str, job_ctx: str):
    """Generate a personalized draft for the selected candidate."""
    if not email_addr:
        return "", "", "❌ Select a candidate first."
    candidate = next(
        (r for r in _last_results if r["metadata"].get("email", "") == email_addr),
        None,
    )
    if not candidate:
        return "", "", "❌ Candidate not found in last results."
    subject, body, status = send_personalized_email(candidate, job_context=job_ctx)
    return subject, body, status

